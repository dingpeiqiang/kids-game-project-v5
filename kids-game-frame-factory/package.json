{
  "name": "kids-game-frame-factory",
  "version": "1.0.0",
  "description": "通用儿童游戏开发框架 - 基于组件化架构的可复用游戏框架",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "docs": "typedoc src/index.ts --out docs/api",
    "clean": "rimraf dist"
  },
  "keywords": [
    "game",
    "framework",
    "phaser",
    "vue",
    "typescript",
    "kids-game",
    "component",
    "reusable"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/kids-game-frame-factory.git"
  },
  "peerDependencies": {
    "phaser": "^3.60.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "phaser": "^3.90.0",
    "typescript": "^5.1.6",
    "vite": "^4.4.0",
    "vitest": "^0.33.0",
    "vue": "^3.3.4",
    "rimraf": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
