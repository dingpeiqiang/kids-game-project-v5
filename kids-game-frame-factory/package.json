{
  "name": "kids-game-frame-factory",
  "version": "3.1.0",
  "description": "AI友好的游戏开发框架，基于 Phaser 3 + TypeScript",
  "private": true,
  "scripts": {
    "dev": "echo \"请使用 game-wizard.bat 或 npm run wizard 开始新游戏开发\" && echo \"或在项目目录中使用 npm run dev\"",
    "wizard": "node scripts/enhance-dev-tools.js guide",
    "create": "node scripts/enhance-dev-tools.js create",
    "validate": "node scripts/enhance-dev-tools.js validate",
    "analyze": "node scripts/enhance-dev-tools.js analyze",
    "upgrade": "node scripts/enhance-dev-tools.js upgrade",
    "check": "node scripts/enhance-dev-tools.js check",
    "version": "node scripts/enhance-dev-tools.js version",
    "resource:init": "node scripts/resource-generator.js init",
    "resource:placeholder": "node scripts/resource-generator.js placeholder",
    "resource:validate": "node scripts/resource-generator.js validate",
    "resource:optimize": "node scripts/resource-generator.js optimize",
    "test:tools": "node scripts/tools-test.js"
  },
  "bin": {
    "game-wizard": "scripts/game-wizard.bat",
    "game-wizard-ps1": "scripts/GameWizard.ps1"
  },
  "keywords": ["game", "phaser", "typescript", "ai", "kids", "framework"],
  "author": "KidsGame Team",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "chalk": "^4.1.2",
    "inquirer": "^8.2.5",
    "sharp": "^0.33.3",
    "@types/node": "^18.17.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}