{
  "name": "plane-shooter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "飞机大战 - 儿童射击小游戏",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "generate-resources": "node scripts/generate-resources.mjs",
    "generate-audio": "node scripts/generate-audio.mjs",
    "register": "node register-game-api.js",
    "register:sql": "echo '请在 MySQL 客户端执行：source register-game.sql'"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "pinia": "^2.1.0",
    "vue-router": "^4.2.0",
    "phaser": "^3.70.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "sharp": "^0.33.0"
  }
}
