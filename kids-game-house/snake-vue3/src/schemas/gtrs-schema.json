{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kids-game.com/schemas/gtrs-v1.0.0.json",
  "title": "Game Theme Resource Specification v1.0.0",
  "description": "GTRS 游戏主题资源规范 Schema，用于全流程 JSON 校验",
  "type": "object",
  "required": ["specMeta", "themeInfo", "globalStyle", "resources"],
  "additionalProperties": true,
  "properties": {
    "specMeta": {
      "type": "object",
      "description": "规范元信息",
      "required": ["specName", "specVersion", "compatibleVersion"],
      "additionalProperties": false,
      "properties": {
        "specName": {
          "type": "string",
          "const": "GTRS",
          "description": "规范名称，固定为 GTRS"
        },
        "specVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "当前规范版本号，格式：主版本。次版本。修订版"
        },
        "compatibleVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "向下兼容的最低版本"
        }
      }
    },
    "themeInfo": {
      "type": "object",
      "description": "主题基础信息",
      "required": ["themeId", "gameId", "themeName", "isDefault"],
      "additionalProperties": true,
      "properties": {
        "themeId": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "主题唯一标识，仅英文小写、数字、下划线"
        },
        "gameId": {
          "type": "string",
          "description": "归属游戏 ID"
        },
        "themeName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "description": "主题中文名称，1-50 字"
        },
        "isDefault": {
          "type": "boolean",
          "description": "是否为默认主题"
        },
        "author": {
          "type": "string",
          "description": "主题作者"
        },
        "description": {
          "type": "string",
          "maxLength": 500,
          "description": "主题描述，不超过 500 字"
        }
      }
    },
    "globalStyle": {
      "type": "object",
      "description": "全局样式定义",
      "required": [],
      "additionalProperties": true,
      "properties": {
        "primaryColor": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "主色调，十六进制颜色"
        },
        "secondaryColor": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "辅助色"
        },
        "bgColor": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "背景色"
        },
        "textColor": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "文字颜色"
        },
        "fontFamily": {
          "type": "string",
          "description": "字体家族"
        },
        "borderRadius": {
          "type": "string",
          "pattern": "^\\d+px$",
          "description": "圆角大小，单位 px"
        }
      }
    },
    "resources": {
      "type": "object",
      "description": "主题资源集合",
      "required": ["images", "audio", "video"],
      "additionalProperties": true,
      "properties": {
        "images": {
          "type": "object",
          "required": ["login", "scene", "ui", "icon", "effect"],
          "properties": {
            "login": { "$ref": "#/definitions/resourceMap" },
            "scene": { "$ref": "#/definitions/resourceMap" },
            "ui": { "$ref": "#/definitions/resourceMap" },
            "icon": { "$ref": "#/definitions/resourceMap" },
            "effect": { "$ref": "#/definitions/resourceMap" }
          }
        },
        "audio": {
          "type": "object",
          "required": ["bgm", "effect", "voice"],
          "properties": {
            "bgm": { "$ref": "#/definitions/audioResourceMap" },
            "effect": { "$ref": "#/definitions/audioResourceMap" },
            "voice": { "$ref": "#/definitions/audioResourceMap" }
          }
        },
        "video": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  },
  "definitions": {
    "resourceMap": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["src", "type", "alias"],
        "properties": {
          "src": {
            "type": "string",
            "description": "资源路径或 URL"
          },
          "type": {
            "type": "string",
            "enum": ["png", "jpg", "jpeg", "webp", "gif"],
            "description": "图片格式"
          },
          "alias": {
            "type": "string",
            "description": "中文别名"
          }
        }
      }
    },
    "audioResourceMap": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["src", "type", "volume", "alias"],
        "properties": {
          "src": {
            "type": "string",
            "description": "音频路径或 URL"
          },
          "type": {
            "type": "string",
            "enum": ["mp3", "wav", "ogg"],
            "description": "音频格式"
          },
          "volume": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "音量，0-1 之间"
          },
          "alias": {
            "type": "string",
            "description": "中文别名"
          }
        }
      }
    }
  }
}
