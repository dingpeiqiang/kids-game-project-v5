# ========================================
# 儿童游戏平台 - 环境变量配置文件
# ========================================

# ---------------------------
# 数据库配置（外部部署）
# ---------------------------
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/kidgame?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_USER=kidgame
MYSQL_PASSWORD=your-secure-database-password

# ---------------------------
# Redis 配置（外部部署）
# ---------------------------
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# ---------------------------
# JWT 配置
# ---------------------------
# JWT 密钥（至少 32 字符，生产环境请使用强密钥）
JWT_SECRET=your-super-secure-jwt-secret-min-32-chars

# ---------------------------
# 前端配置
# ---------------------------
# 前端 API 基础地址（生产环境请使用域名）
VITE_API_BASE_URL=http://localhost:8080

# ---------------------------
# 腾讯云 COS 配置（可选，用于资源存储）
# ---------------------------
COS_SECRET_ID=your-tencent-cos-secret-id
COS_SECRET_KEY=your-tencent-cos-secret-key
COS_BUCKET=kids-game-resources-your-app-id
COS_REGION=ap-guangzhou

# ---------------------------
# 上传方式配置
# ---------------------------
# 可选值：cos（腾讯云COS）、local（本地存储）
VITE_UPLOAD_METHOD=local

# ---------------------------
# 日志配置
# ---------------------------
# 日志级别：DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO