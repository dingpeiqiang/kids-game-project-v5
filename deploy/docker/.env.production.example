# ========================================
# 生产环境配置文件
# 使用说明：
# 1. 复制此文件为 .env.production
# 2. 修改下面的配置值（特别是密码和密钥）
# 3. 部署时使用：docker-compose --env-file .env.production up -d
# ========================================

# ========================================
# MySQL 数据库配置（外部部署）
# ========================================
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/kidgame?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_USER=kidgame
MYSQL_PASSWORD=Ding@12435

# ========================================
# Redis 配置（外部部署）
# ========================================
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# ========================================
# 资源上传配置
# ========================================
# 方式 1：本地存储（默认）
# 文件存储在服务器本地 ./uploads 目录

# 方式 2：SFTP（可选，需要在 application.yml 中配置）
# 参考 application.yml.example 中的 SFTP 配置部分

# ========================================
# JWT 配置
# ========================================
JWT_SECRET=7a2f9d3e8b1c5e7f0a9d4s6k2j8h5g71p0o9i8u7y6t5r4e3w2q1

# ========================================
# 前端配置
# ========================================
VITE_API_BASE_URL=http://8.136.156.190:8080
VITE_UPLOAD_METHOD=local

# ========================================
# 后端配置
# ========================================
SPRING_PROFILES_ACTIVE=prod

# ========================================
# Docker 配置
# ========================================
COMPOSE_PROJECT_NAME=kids-game
