# 低内存服务器：复制为 .env 后与 docker-compose.yml 一起使用
#   cp .env.lowmem.example .env
#   docker compose up -d

BACKEND_DOCKERFILE=deploy/docker/Dockerfile.backend.lowmem
JAVA_OPTS=-Xms128m -Xmx256m -XX:MetaspaceSize=64m -XX:MaxMetaspaceSize=128m -XX:+UseSerialGC -Djava.security.egd=file:/dev/./urandom

# 可选：取消下行注释并在 compose 中为 mysql/redis 启用对应 command（见 LOW_MEMORY_DEPLOY.md）
# COMPOSE_LOWMEM=1