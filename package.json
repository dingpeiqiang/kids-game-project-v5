{
  "name": "kids-game-monorepo",
  "private": true,
  "version": "5.0.0",
  "description": "Kids game platform — single frontend app",
  "scripts": {
    "dev": "pnpm --filter kids-game-frontend dev",
    "dev:frontend": "pnpm --filter kids-game-frontend dev",
    "build": "pnpm --filter kids-game-frontend build",
    "build:frontend": "pnpm --filter kids-game-frontend build",
    "fix:game-imports": "node scripts/fix-frontend-game-shell-imports.mjs",
    "check:frontend": "node scripts/ensure-frontend-games.mjs && node scripts/fix-frontend-game-shell-imports.mjs && pnpm --filter kids-game-frontend run audit && pnpm --filter kids-game-frontend run type-check",
    "integrate:packages": "node scripts/integrate-packages-into-frontend.mjs",
    "remove:packages": "node scripts/remove-packages-dir.mjs",
    "finalize:packages": "node scripts/integrate-packages-into-frontend.mjs && node scripts/remove-packages-dir.mjs",
    "remove:simple": "node scripts/remove-kids-game-simple.mjs"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@9.15.0"
}