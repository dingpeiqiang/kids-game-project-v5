# ========================================
# 生产环境配置文件
# 使用说明：
# 1. 复制此文件为 .env.production
# 2. 修改下面的配置值（特别是密码和密钥）
# 3. 部署时使用：docker-compose --env-file .env.production up -d
# ========================================

# ========================================
# MySQL 数据库配置
# ========================================
MYSQL_ROOT_PASSWORD=your-secure-root-password-here
MYSQL_DATABASE=kids_game
MYSQL_USER=kidgame
MYSQL_PASSWORD=your-secure-database-password-here

# ========================================
# 资源上传配置（三选一）
# ========================================
# 方式 1：本地存储（默认，无需额外配置）
# 文件存储在服务器本地 ./uploads 目录

# 方式 2：腾讯云 COS（可选，需要配置以下参数）
# 如果使用 COS，请取消注释并填写以下配置
# COS_SECRET_ID=your-tencent-cos-secret-id
# COS_SECRET_KEY=your-tencent-cos-secret-key
# COS_BUCKET=kids-game-resources-your-app-id
# COS_REGION=ap-guangzhou

# 方式 3：SFTP（可选，需要在 application.yml 中配置）
# 参考 application.yml.example 中的 SFTP 配置部分

# ========================================
# JWT 配置
# ========================================
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production-min-32-chars

# ========================================
# 前端配置
# ========================================
VITE_API_BASE_URL=https://your-domain.com/api
VITE_UPLOAD_METHOD=cos

# ========================================
# 后端配置
# ========================================
SPRING_PROFILES_ACTIVE=prod

# ========================================
# Docker 配置
# ========================================
COMPOSE_PROJECT_NAME=kids-game
