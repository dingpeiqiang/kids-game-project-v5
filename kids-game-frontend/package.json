{
  "name": "kids-game-frontend",
  "version": "1.0.0",
  "description": "统一前端（src 含业务、游戏、shared；shell 为终端壳）",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:clean": "node clean-vite-cache.js && vite",
    "preaudit": "node ../scripts/ensure-frontend-games.mjs",
    "build": "node ../scripts/ensure-frontend-games.mjs && node scripts/audit-framework-registry.mjs && node scripts/audit-gtrs-lifecycle.mjs && node scripts/audit-mobile-control-registry.mjs && node scripts/audit-game-orientation.mjs && node clean-vite-cache.js && node scripts/generate-version.js dist && pnpm exec vite build",
    "build:fast": "pnpm exec vite build",
    "build:version": "node scripts/generate-version.js dist",
    "preview": "vite preview",
    "clean": "node clean-vite-cache.js",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "type-check": "vue-tsc --noEmit",
    "type-check:shell": "vue-tsc --noEmit -p tsconfig.shell.json",
    "audit": "node scripts/audit-framework-registry.mjs && node scripts/audit-gtrs-lifecycle.mjs && node scripts/audit-mobile-control-registry.mjs && node scripts/audit-game-orientation.mjs",
    "cap:sync:android": "pnpm exec cap sync android",
    "cap:sync:android:remote": "node scripts/cap-sync-android-remote.mjs"
  },
  "dependencies": {
    "@babylonjs/core": "^7.49.0",
    "@babylonjs/loaders": "^7.54.3",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@element-plus/icons-vue": "^2.3.2",
    "@types/marked": "^5.0.2",
    "ajv": "^8.18.0",
    "axios": "^1.6.0",
    "compressorjs": "^1.2.1",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.5",
    "file-saver": "^2.0.5",
    "flexsearch": "^0.8.212",
    "jsencrypt": "^3.3.2",
    "jszip": "^3.10.1",
    "lamejs": "^1.2.1",
    "marked": "^15.0.0",
    "phaser": "3.90.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-cropper": "^1.1.4",
    "vue-router": "^4.2.0",
    "vuedraggable": "^4.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/echarts": "^4.9.22",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.5.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "sass": "^1.98.0",
    "tailwindcss": "^3.4.0",
    "terser": "^5.48.0",
    "typescript": "5.4",
    "vite": "^5.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vue-tsc": "^1.8.0"
  }
}
