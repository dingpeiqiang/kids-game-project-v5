// 从后台加载官方主题
async function loadOfficialThemes(): Promise<void> {
  loadingOfficialThemes.value = true;
  try {
    // 从后台查询所有状态为 on_sale 的主题
    const response = await themeApi.getList({ status: 'on_sale' });
    
    if (response.success && response.data) {
      // 将云主题转换为官方主题格式
      officialThemes.value = response.data.map((theme: CloudThemeInfo) => ({
        id: theme.id,
        name: theme.name,
        type: 'game', // 默认设为游戏主题，后续可以根据实际数据判断
        category: '游戏主题',
        description: theme.description || '',
        baseThemeKey: 'default',
        styleOverrides: {},
        assetOverrides: {},
      }));
      
      console.log('[CreatorCenter] 官方主题加载成功:', officialThemes.value.length);
    } else {
      console.warn('[CreatorCenter] 官方主题加载失败:', response.message);
      // 使用默认的硬编码主题作为回退
      loadDefaultOfficialThemes();
    }
  } catch (error) {
    console.error('[CreatorCenter] 加载官方主题出错:', error);
    // 出错时使用默认主题
    loadDefaultOfficialThemes();
  } finally {
    loadingOfficialThemes.value = false;
  }
}

// 加载默认的硬编码官方主题 (作为回退方案)
function loadDefaultOfficialThemes(): void {
  // TODO: 这里可以放回原来的硬编码数据作为回退
  console.log('[CreatorCenter] 使用默认官方主题数据');
}

// 资源服务器配置
const RESOURCE_SERVER_CONFIG = {
  // 默认资源服务器地址（可配置）
  defaultServerUrl: 'http://192.168.1.100:8080',
  // CDN 节点（可选，用于负载均衡）
  cdnNodes: [
    'http://cdn1.example.com:8080',
    'http://cdn2.example.com:8080',
  ],
  // 是否启用 CDN
  useCDN: false,
};

// 从资源包提取资源 URLs（直接使用已有的完整 URL）
function extractAssetURLsFromPack(resourcePack: any): Record<string, string> {
  if (!resourcePack || !resourcePack.resources) {
    return {};
  }
  
  const assets: Record<string, string> = {};
  const serverStats = new Map<string, number>(); // 统计不同服务器数量
  
  Object.entries(resourcePack.resources).forEach(([key, resource]: [string, any]) => {
    if (resource.url) {
      assets[key] = resource.url;
      
      // 统计服务器分布 - 处理相对路径和绝对路径
      try {
        // 如果是相对路径，使用 window.location.origin 构建完整 URL
        const fullUrl = resource.url.startsWith('/') 
          ? `${window.location.origin}${resource.url}`
          : resource.url;
        
        const urlObj = new URL(fullUrl);
        const serverKey = `${urlObj.protocol}//${urlObj.host}`;
        serverStats.set(serverKey, (serverStats.get(serverKey) || 0) + 1);
      } catch (e) {
        // 相对路径解析失败时，记录为本地资源
        if (resource.url.startsWith('/')) {
          const localServer = `${window.location.protocol}//${window.location.host}`;
          serverStats.set(localServer, (serverStats.get(localServer) || 0) + 1);
        } else {
          console.debug('[资源包] URL 格式特殊:', resource.url);
        }
      }
    }
  });
  
  console.log('[资源包] 提取的资源 URLs:', {
    packId: resourcePack.packId,
    version: resourcePack.version,
    totalResources: Object.keys(assets).length,
    serverDistribution: Object.fromEntries(serverStats),
    sampleAssets: Object.fromEntries(
      Object.entries(assets).slice(0, 3)
    ),
  });
  
  return assets;
}

// 从官方主题开始 DIY
function diyFromOfficial(theme: any): void {
  currentTab.value = 'create';
  createStep.value = 'info';
  
  // 记录 DIY 来源主题
  diySourceTheme.value = theme;
  
  // 预填充基础主题信息
  newTheme.baseThemeKey = theme.baseThemeKey;
  newTheme.name = ''; // 名称必须为空，让用户自己填写
  newTheme.author = '';
  newTheme.description = theme.description || `基于${theme.name}的个性化主题`;
  newTheme.price = 0;
  
  // 复制官方主题的样式配置作为默认值
  Object.keys(newThemeStyles).forEach(key => {
    delete newThemeStyles[key];
  });
  if (theme.styleOverrides) {
    Object.assign(newThemeStyles, theme.styleOverrides);
  } else {
    console.log('[DIY] 主题没有 styleOverrides，使用默认配置');
  }
  
  // 复制官方主题的资产配置作为默认值
  Object.keys(newThemeAssets).forEach(key => {
    delete newThemeAssets[key];
  });
  
  // 关键：优先从资源包提取资源 URL
  let sourceAssets: Record<string, string> = {};
  
  if (theme.resourcePack) {
    // 从资源包提取完整 URL（每个资源可能来自不同服务器）
    sourceAssets = extractAssetURLsFromPack(theme.resourcePack);
    console.log('[DIY] 从去中心化资源服务器加载:', {
      packId: theme.resourcePack.packId,
      version: theme.resourcePack.version,
      resourcesCount: Object.keys(sourceAssets).length,
    });
  } else if (theme.assetOverrides) {
    // 兼容旧的直接配置方式
    sourceAssets = { ...theme.assetOverrides };
    console.log('[DIY] 使用旧方式资源配置:', Object.keys(sourceAssets).length);
  }
  
  // 只复制 assetKeys 中存在的资源
  if (sourceAssets && assetKeys.value.length > 0) {
    assetKeys.value.forEach(key => {
      if (sourceAssets[key]) {
        newThemeAssets[key] = sourceAssets[key];
      }
    });
    console.log('[DIY] 已加载资产配置:', {
      totalKeys: assetKeys.value.length,
      loadedAssets: Object.keys(newThemeAssets).length,
      sampleAssets: Object.fromEntries(
        Object.entries(newThemeAssets).slice(0, 3)
      ),
    });
  } else if (sourceAssets) {
    // 如果 assetKeys 还没有加载，直接复制所有资产
    Object.assign(newThemeAssets, sourceAssets);
    console.log('[DIY] assetKeys 未就绪，临时加载所有资产:', Object.keys(newThemeAssets).length);
  } else {
    console.log('[DIY] 主题没有资源配置');
  }
  
  console.log('[DIY] 已加载来源主题数据:', {
    sourceTheme: theme.name,
    baseThemeKey: newTheme.baseThemeKey,
    stylesCount: Object.keys(newThemeStyles).length,
    assetsCount: Object.keys(newThemeAssets).length,
    assetKeysReady: assetKeys.value.length > 0,
    hasResourcePack: !!theme.resourcePack,
  });
  
  // 提示用户
  alert(`将基于"${theme.name}"创建您的个性化主题\n已加载该主题的所有配置\n您只需要设置一个独特的主题名称即可发布！`);
}

// 取消创作
function cancelCreate(): void {
  if (confirm('确定要取消创作吗？所有未保存的内容将丢失。')) {
    resetNewTheme();
    currentTab.value = 'official';
  }
}

// 查看官方主题
function viewOfficialTheme(theme: any): void {
  // 这里可以打开主题详情模态框或跳转到详情页
  console.log('View official theme:', theme);
  alert(`查看官方主题：${theme.name}\n${theme.description}\n\n点击 "DIY" 按钮可以基于此主题创建您自己的版本！`);
}

// 重置新主题
function resetNewTheme(): void {
  newTheme.name = '';
  newTheme.author = '';
  newTheme.baseThemeKey = 'default';
  newTheme.description = '';
  newTheme.price = 0;
  
  Object.keys(newThemeStyles).forEach(key => {
    delete newThemeStyles[key];
  });
  
  Object.keys(newThemeAssets).forEach(key => {
    delete newThemeAssets[key];
  });
  
  diySourceTheme.value = null; // 清空来源主题
}

// 格式样式键
function formatStyleKey(key: string): string {
  return key
    .replace(/_/g, ' ')
    .replace(/\b\w/g, (l) => l.toUpperCase());
}

// 格式资产键
function formatAssetKey(key: string): string {
  return key.replace(/_/g, ' ');
}

// 获取文件接受类型
function getFileAccept(key: string): string {
  if (key.includes('bgm') || key.includes('sound') || key.includes('audio')) {
    return 'audio/*';
  }
  return 'image/*';
}

// 检查是否为图片
function isImage(path: string): boolean {
  return /\.(png|jpg|jpeg|webp|gif)$/i.test(path);
}

// 检查是否为音频
function isAudio(path: string): boolean {
  if (!path) return false;
  // 检查文件扩展名或 data URL 类型
  if (path.startsWith('data:')) {
    return path.startsWith('data:audio/');
  }
  return /\.(mp3|wav|ogg|m4a)$/i.test(path);
}

// 获取资产类型标签
function getAssetTypeLabel(key: string): string {
  if (key.includes('bgm') || key.includes('music')) return '背景音乐';
  if (key.includes('sound') || key.includes('effect')) return '音效';
  if (key.includes('img') || key.includes('image')) return '图片';
  if (key.includes('bg') || key.includes('background')) return '背景';
  return '资源';
}

// 获取资产类型样式类
function getAssetTypeClass(key: string): string {
  if (key.includes('bgm') || key.includes('music')) return 'type-music';
  if (key.includes('sound') || key.includes('effect')) return 'type-sound';
  if (key.includes('img') || key.includes('image')) return 'type-image';
  if (key.includes('bg') || key.includes('background')) return 'type-bg';
  return 'type-default';
}

// 获取资产名称
function getAssetName(path: string): string {
  if (path.startsWith('data:')) {
    return '上传的文件';
  }
  return path.split('/').pop() || '文件';
}

// 处理资产上传
function handleAssetUpload(key: string, event: Event): void {
  const input = event.target as HTMLInputElement;
  const file = input.files?.[0];
  if (!file) return;
  
  const reader = new FileReader();
  reader.onload = (e) => {
    const result = e.target?.result as string;
    newThemeAssets[key] = result;
    console.log(`[资源上传] ${key} 上传成功`);
  };
  reader.readAsDataURL(file);
}

// 打开图片预览
function openImagePreview(key: string): void {
  const path = newThemeAssets[key];
  if (!path || !isImage(path)) return;
  
  const win = window.open('', '_blank');
  if (win) {
    win.document.write(`
      <!DOCTYPE html>
      <html>
        <head>
          <title>${formatAssetKey(key)} - 图片预览</title>
          <style>
            body {
              margin: 0;
              padding: 20px;
              background: #1a1a1a;
              display: flex;
              justify-content: center;
              align-items: center;
              min-height: 100vh;
            }
            img {
              max-width: 90%;
              max-height: 90vh;
              border-radius: 8px;
              box-shadow: 0 8px 32px rgba(0,0,0,0.5);
            }
          </style>
        </head>
        <body>
          <img src="${path}" alt="${formatAssetKey(key)}" />
        </body>
      </html>
    `);
  }
}

// 播放音频
function playAudio(key: string): void {
  const path = newThemeAssets[key];
  if (!path || !isAudio(path)) return;
  
  // 如果正在播放同一个音频，停止播放
  if (currentPlayingKey.value === key && currentAudio.value) {
    stopAudio();
    return;
  }
  
  // 停止当前正在播放的音频
  stopAudio();
  
  // 创建并播放新音频
  const audio = new Audio(path);
  currentAudio.value = audio;
  currentPlayingKey.value = key;
  
  audio.addEventListener('ended', () => {
    currentPlayingKey.value = null;
    currentAudio.value = null;
  });
  
  audio.addEventListener('error', (e) => {
    console.error('[音频播放] 播放失败:', e);
    alert('音频播放失败，请检查文件是否完整');
    currentPlayingKey.value = null;
    currentAudio.value = null;
  });
  
  audio.play().catch(err => {
    console.error('[音频播放] 播放错误:', err);
    alert('音频播放失败');
    currentPlayingKey.value = null;
    currentAudio.value = null;
  });
}

// 停止音频播放
function stopAudio(): void {
  if (currentAudio.value) {
    currentAudio.value.pause();
    currentAudio.value.currentTime = 0;
    currentAudio.value = null;
  }
  currentPlayingKey.value = null;
}

// 上一步
function prevStep(): void {
  const steps = createSteps.map(step => step.id);
  const currentIndex = steps.indexOf(createStep.value);
  if (currentIndex > 0) {
    createStep.value = steps[currentIndex - 1];
  }
}

// 下一步
function nextStep(): void {
  const steps = createSteps.map(step => step.id);
  const currentIndex = steps.indexOf(createStep.value);
  if (currentIndex < steps.length - 1) {
    createStep.value = steps[currentIndex + 1];
  }
}

// 发布主题
async function publishTheme(): Promise<void> {
  if (!canPublish.value) return;
  
  try {
    const themeData: DiyThemeData = {
      baseThemeKey: newTheme.baseThemeKey,
      name: newTheme.name,
      author: newTheme.author,
      assetOverrides: { ...newThemeAssets },
      styleOverrides: { ...newThemeStyles },
      createdAt: Date.now(),
      updatedAt: Date.now(),
    };
    
    if (publishOptions.saveLocally) {
      const themeKey = themeManager.addLocalDiyTheme(themeData);
      console.log('Theme saved locally:', themeKey);
    }
    
    if (publishOptions.uploadToStore) {
      const result = await themeManager.uploadDiyToCloud(
        themeData,
        newTheme.price,
      );
      if (result) {
        alert('主题发布成功！');
        // 重置表单
        resetNewTheme();
        createStep.value = 'info';
        // 重新加载我的主题
        await loadMyThemes();
        // 切换到我的主题页面
        currentTab.value = 'my-themes';
      } else {
        alert('发布失败，请重试');
      }
    } else {
      alert('主题已保存到本地！');
      resetNewTheme();
      createStep.value = 'info';
    }
  } catch (e) {
    console.error('[CreatorCenter] Publish failed:', e);
    alert('发布失败');
  }
}

// 购买或下载主题
async function handleBuyOrDownload(theme: CloudThemeInfo): Promise<void> {
  if (theme.owned) {
    await downloadTheme(theme.id);
    return;
  }
  
  if (theme.price > 0) {
    // 显示购买确认
    if (confirm(`确定要购买主题 "${theme.name}" 吗？\n价格：${theme.price} 趣乐币`)) {
      await buyTheme(theme);
    }
  } else {
    await downloadTheme(theme.id);
  }
}

