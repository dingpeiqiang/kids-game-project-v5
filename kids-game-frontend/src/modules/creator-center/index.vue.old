  if (officialFilter.value === 'all') {
    return officialThemes.value;
  }
  return officialThemes.value.filter(theme => theme.type === officialFilter.value);
});

const previewStyles = computed(() => ({
  backgroundColor: newThemeStyles.color_bg || '#333333',
  padding: '20px',
  borderRadius: newThemeStyles.border_radius_card || '8px',
}));

// 获取资产的显示路径（包含默认值）
const getAssetPath = (key: string) => computed(() => {
  return newThemeAssets[key] || '';
});

const canProceed = computed(() => {
  switch (createStep.value) {
    case 'info':
      return newTheme.name.trim() !== '' && newTheme.author.trim() !== '';
    case 'styles':
      return Object.keys(newThemeStyles).length > 0;
    case 'assets':
      return true; // 资产可选
    default:
      return true;
  }
});

const canPublish = computed(() => {
  return newTheme.name.trim() !== '' && 
         newTheme.author.trim() !== '' && 
         (publishOptions.saveLocally || publishOptions.uploadToStore);
});

// 生命周期
