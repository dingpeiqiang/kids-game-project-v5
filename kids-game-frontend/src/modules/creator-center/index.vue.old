    // }
    alert('购买功能开发中...');
  } catch (e) {
    console.error('[CreatorCenter] Buy failed:', e);
    alert('购买失败');
  } finally {
    isPurchasing.value = false;
  }
}

// 下载主题
async function downloadTheme(themeId: string): Promise<void> {
  try {
    const success = await themeManager.downloadCloudTheme(themeId);
    if (success) {
      alert('主题下载成功！');
    } else {
      alert('下载失败');
    }
  } catch (e) {
    console.error('[CreatorCenter] Download failed:', e);
    alert('下载失败');
  }
}

// 预览主题
function previewTheme(theme: CloudThemeInfo): void {
  console.log('Preview theme:', theme);
  // 这里可以打开主题预览模态框
}
