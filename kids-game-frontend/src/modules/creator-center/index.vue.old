  color: #333;
  margin: 0 0 8px 0;
}

.theme-desc {
  font-size: 13px;
  color: #666;
  line-height: 1.5;
  margin: 0;
}

.theme-actions {
  display: flex;
  gap: 8px;
  padding: 16px;
  border-top: 1px solid #f0f0f0;
}

.btn-action {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 10px 16px;
  border: none;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}

.action-icon {
  font-size: 16px;
}

.btn-view {
  background: #f5f5f5;
  color: #666;
}

.btn-view:hover {
  background: #e0e0e0;
}

.btn-diy {
  background: linear-gradient(135deg, #4ECDC4 0%, #45B7D1 100%);
  color: white;
}

.btn-diy:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(78, 205, 196, 0.3);
}

/* 创作页面头部 */
.create-header-with-back {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
  padding-bottom: 16px;
  border-bottom: 2px solid #f0f0f0;
}

.btn-cancel-create {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
  border: none;
  border-radius: 8px;
  color: #dc2626;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-cancel-create:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
}

.cancel-icon {
  font-size: 16px;
}

.create-placeholder {
  width: 100px; /* 占位，保持标题居中 */
}

.section {
  background: white;
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  padding: 24px;
  margin-bottom: 24px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
  padding-bottom: 16px;
  border-bottom: 1px solid #eee;
}

.section-title {
  margin: 0;
  font-size: 24px;
  font-weight: 600;
  color: #333;
}

/* 按钮样式 */
.btn-create {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  border: none;
  border-radius: 8px;
  color: white;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-create:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(255, 107, 157, 0.3);
}

.btn-go-official {
  padding: 12px 32px;
  background: linear-gradient(135deg, #4ECDC4 0%, #45B7D1 100%);
  border: none;
  border-radius: 8px;
  color: white;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-go-official:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(78, 205, 196, 0.3);
}

.btn-create-empty {
  padding: 12px 32px;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  border: none;
  border-radius: 8px;
  color: white;
  font-size: 16px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-create-empty:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(255, 107, 157, 0.3);
}

/* 加载和空状态 */
.loading-state,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  color: #888;
  gap: 16px;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid #f0f0f0;
  border-top-color: #4ECDC4;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-illustration {
  font-size: 64px;
  margin-bottom: 16px;
}

.empty-state h3 {
  margin: 0;
  font-size: 20px;
  color: #333;
}

.empty-state p {
  margin: 0;
  color: #666;
}

/* 主题网格 */
.themes-grid,
.store-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 20px;
}

.theme-card,
.store-theme-card {
  background: #f9f9f9;
  border-radius: 12px;
  overflow: hidden;
  transition: all 0.2s;
}

.theme-card:hover,
.store-theme-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
}

.theme-card.on-sale {
  border: 2px solid #4ECDC4;
}

/* 缩略图 */
.theme-thumbnail {
  position: relative;
  width: 100%;
  padding-top: 60%;
  overflow: hidden;
  cursor: pointer;
}

.thumbnail-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s;
}

.theme-thumbnail:hover .thumbnail-img {
  transform: scale(1.05);
}

.thumbnail-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #42b983, #3d5afe);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 48px;
  font-weight: bold;
}

.sale-badge,
.offline-badge,
.free-badge {
  position: absolute;
  top: 8px;
  left: 8px;
  padding: 4px 10px;
  font-size: 12px;
  font-weight: 600;
  border-radius: 4px;
  color: white;
}

.sale-badge {
  background: #4ECDC4;
}

.offline-badge {
  background: #888;
}

.free-badge {
  background: #42b983;
}

.theme-price {
  position: absolute;
  bottom: 8px;
  right: 8px;
  padding: 4px 10px;
  background: rgba(0, 0, 0, 0.7);
  color: white;
  font-size: 12px;
  font-weight: 600;
  border-radius: 4px;
}

/* 主题信息 */
.theme-info {
  padding: 16px;
}

.theme-name {
  margin: 0 0 8px 0;
  font-size: 16px;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.theme-author {
  margin: 0 0 12px 0;
  color: #666;
  font-size: 13px;
}

.theme-meta {
  display: flex;
  gap: 12px;
  color: #888;
  font-size: 13px;
}

.meta-icon {
  margin-right: 4px;
}

.theme-earnings {
  color: #4ECDC4;
  font-weight: 500;
}

/* 主题操作 */
.theme-actions {
  display: flex;
  gap: 8px;
  padding: 12px 16px;
  border-top: 1px solid #eee;
}

.btn-action {
  flex: 1;
  padding: 8px 12px;
  border: none;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-action:hover:not(:disabled) {
  opacity: 0.9;
}

.btn-action:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.btn-offline {
  background: #ff6b6b;
  color: white;
}

.btn-online {
  background: #4ECDC4;
  color: white;
}

.btn-edit {
  background: #45B7D1;
  color: white;
}

.btn-stats {
  background: #A66CFF;
  color: white;
}

/* 商店相关 */
.store-filters {
  display: flex;
  align-items: center;
  gap: 12px;
}

.filter-btn {
  padding: 6px 16px;
  background: #f0f0f0;
  border: none;
  border-radius: 6px;
  color: #666;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s;
}

.filter-btn:hover {
  background: #e0e0e0;
}

.filter-btn.active {
  background: #45B7D1;
  color: white;
}

.search-input {
  padding: 8px 12px;
  border: 1px solid #ddd;
  border-radius: 6px;
  font-size: 14px;
  min-width: 200px;
}

.search-input:focus {
  outline: none;
  border-color: #45B7D1;
}

.store-theme-card.owned {
  opacity: 0.8;
}

.theme-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  border-top: 1px solid #eee;
}

.btn-buy {
  padding: 8px 16px;
  background: linear-gradient(135deg, #45B7D1 0%, #A66CFF 100%);
  border: none;
  border-radius: 6px;
  color: white;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-buy:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 2px 8px rgba(69, 183, 209, 0.3);
}

.btn-buy:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.btn-buy.owned {
  background: #42b983;
}

/* 主题创作 */
.create-container {
  max-width: 1000px;
  margin: 0 auto;
}

.create-header {
  text-align: center;
  margin-bottom: 32px;
}

.create-title {
  margin: 0 0 8px 0;
  font-size: 32px;
  font-weight: 600;
  color: #333;
}

.create-subtitle {
  margin: 0;
  color: #666;
  font-size: 16px;
}

.create-steps {
  display: flex;
  justify-content: space-between;
  margin-bottom: 32px;
  position: relative;
}

.create-steps::before {
  content: '';
  position: absolute;
  top: 20px;
  left: 50px;
  right: 50px;
  height: 2px;
  background: #e0e0e0;
  z-index: 1;
}

.create-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 2;
  flex: 1;
}

.step-number {
  width: 40px;
  height: 40px;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 600;
  color: #666;
  margin-bottom: 8px;
  transition: all 0.2s;
}

.create-step.active .step-number {
  background: #4ECDC4;
  color: white;
  box-shadow: 0 2px 8px rgba(78, 205, 196, 0.3);
}

.step-info {
  text-align: center;
}

.step-title {
  margin: 0 0 4px 0;
  font-size: 14px;
  font-weight: 600;
  color: #333;
}

.step-description {
  margin: 0;
  font-size: 12px;
  color: #888;
  max-width: 120px;
}

/* 表单样式 */
.step-content {
  background: #f9f9f9;
  border-radius: 12px;
  padding: 32px;
  margin-bottom: 24px;
}

.form-group {
  margin-bottom: 20px;
}

.form-label {
  display: block;
  margin-bottom: 8px;
  font-size: 14px;
  font-weight: 500;
  color: #333;
}

.form-input,
.form-textarea {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid #ddd;
  border-radius: 6px;
  font-size: 14px;
  transition: all 0.2s;
}

.form-input:focus,
.form-textarea:focus {
  outline: none;
  border-color: #4ECDC4;
  box-shadow: 0 0 0 2px rgba(78, 205, 196, 0.1);
}

.form-textarea {
  resize: vertical;
  min-height: 80px;
}

.form-hint {
  margin-top: 4px;
  font-size: 12px;
  color: #888;
}

/* 样式编辑器 */
.style-editor {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 32px;
}

.style-preview {
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-card {
  padding: 30px;
  border-radius: 12px;
  text-align: center;
  min-width: 200px;
}

.preview-title {
  margin: 0 0 20px 0;
  font-size: 24px;
  font-weight: 600;
}

.preview-button {
  padding: 12px 30px;
  border: none;
  border-radius: 8px;
  color: white;
  font-size: 16px;
  font-weight: 500;
  cursor: pointer;
  transition: transform 0.2s;
}

.preview-button:hover {
  transform: scale(1.05);
}

.style-controls {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.style-group {
  background: white;
  border-radius: 8px;
  padding: 20px;
}

.style-group-title {
  margin: 0 0 16px 0;
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.color-grid,
.size-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 16px;
}

.color-field,
.size-field {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.color-label,
.size-label {
  font-size: 13px;
  color: #666;
}

.color-input-wrapper {
  display: flex;
  align-items: center;
  gap: 8px;
}

.color-picker {
  width: 40px;
  height: 36px;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  background: transparent;
}

.color-text-input,
.size-input {
  flex: 1;
  padding: 8px 12px;
  border: 1px solid #ddd;
  border-radius: 4px;
  font-size: 13px;
  font-family: monospace;
}

.color-text-input:focus,
.size-input:focus {
  outline: none;
  border-color: #4ECDC4;
}

/* 资产上传 */
.asset-uploader {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px;
}

.asset-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.asset-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px;
  background: white;
  border-radius: 8px;
}

.asset-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.asset-key {
  font-size: 14px;
  font-weight: 500;
  color: #333;
}

.asset-name {
  font-size: 12px;
  color: #888;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200px;
}

.asset-actions {
  display: flex;
  gap: 8px;
}

/* 资产上传 - 合并布局 */
.asset-uploader-container {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.section-title-with-icon {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin: 0 0 16px 0;
  padding-bottom: 12px;
  border-bottom: 2px solid rgba(78, 205, 196, 0.2);
}

.title-icon {
  font-size: 20px;
}

.upload-section {
  background: white;
  border-radius: 12px;
  padding: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.asset-list-compact {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.asset-item-compact {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(248, 249, 250, 0.9) 100%);
  border: 1px solid rgba(78, 205, 196, 0.1);
  border-radius: 8px;
  padding: 16px;
  transition: all 0.2s;
}

.asset-item-compact:hover {
  border-color: rgba(78, 205, 196, 0.3);
  box-shadow: 0 4px 12px rgba(78, 205, 196, 0.15);
}

.asset-header-compact {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.asset-key-compact {
  font-size: 14px;
  font-weight: 600;
  color: #333;
}

.asset-actions-compact {
  display: flex;
  gap: 8px;
}

.btn-upload-compact {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  background: linear-gradient(135deg, #4ECDC4 0%, #45B7D1 100%);
  color: white;
  border: none;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.upload-icon {
  font-size: 16px;
}

.btn-upload-compact:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(78, 205, 196, 0.3);
}

.btn-action-compact {
  padding: 8px 12px;
  border: none;
  border-radius: 6px;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-image {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn-audio {
  width: 40px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  font-size: 16px;
}

.btn-audio.playing {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
  animation: pulse 1s infinite;
}

.btn-action-compact:hover {
  transform: translateY(-1px);
  opacity: 0.9;
}

/* 预览区域 */
.preview-area {
  min-height: 120px;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: all 0.2s;
}

.preview-area-image {
  position: relative;
  overflow: hidden;
  background: #f8f9fa;
  border: 2px solid rgba(102, 126, 234, 0.2);
}

.inline-preview-img {
  max-width: 100%;
  max-height: 200px;
  border-radius: 6px;
  object-fit: contain;
}

.preview-dimensions {
  font-size: 12px;
  color: #666;
  padding: 4px 8px;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 4px;
}

.preview-area-audio {
  background: linear-gradient(135deg, rgba(240, 147, 251, 0.1) 0%, rgba(245, 87, 108, 0.1) 100%);
  border: 2px solid rgba(245, 87, 108, 0.2);
  padding: 16px;
  flex-direction: row;
  gap: 12px;
}

.audio-wave-indicator {
  display: flex;
  align-items: flex-end;
  gap: 3px;
  height: 20px;
}

.audio-wave-indicator span {
  width: 4px;
  height: 8px;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  border-radius: 2px;
  animation: none;
}

.audio-wave-indicator.active span {
  animation: wave 0.5s ease-in-out infinite;
}

.audio-wave-indicator.active span:nth-child(1) {
  animation-delay: 0s;
}

.audio-wave-indicator.active span:nth-child(2) {
  animation-delay: 0.1s;
}

.audio-wave-indicator.active span:nth-child(3) {
  animation-delay: 0.2s;
}

@keyframes wave {
  0%, 100% {
    height: 8px;
  }
  50% {
    height: 20px;
  }
}

.audio-status {
  font-size: 13px;
  color: #666;
  font-weight: 500;
}

.preview-area-empty {
  background: #f0f0f0;
  border: 2px dashed #ddd;
}

.empty-placeholder {
  font-size: 13px;
  color: #999;
}

/* 资源总览区域 */
.preview-section {
  background: white;
  border-radius: 12px;
  padding: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.empty-all {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  padding: 40px;
  color: #999;
}

.empty-icon {
  font-size: 48px;
}

.empty-all p {
  margin: 0;
  font-size: 14px;
}

.preview-grid-compact {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 16px;
}

.preview-card-compact {
  background: white;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  transition: all 0.2s;
}

.preview-card-compact:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
}

.card-image-wrapper {
  position: relative;
  width: 100%;
  height: 140px;
  overflow: hidden;
  background: #f0f0f0;
}

.card-preview-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.card-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.2s;
}

.card-image-wrapper:hover .card-overlay {
  opacity: 1;
}

.overlay-btn {
  width: 40px;
  height: 40px;
  border: none;
  border-radius: 50%;
  background: white;
  color: #333;
  font-size: 20px;
  cursor: pointer;
  transition: all 0.2s;
}

.overlay-btn:hover {
  transform: scale(1.1);
}

.card-audio-wrapper {
  width: 100%;
  height: 140px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
