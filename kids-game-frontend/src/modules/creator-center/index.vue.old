<template>
  <div class="creator-center-container">
    <!-- 顶部导航栏 -->
    <BaseHeader variant="kids" :showThemeSwitcher="false" :showBack="true" @back="goBack">
      <template #left>
        <button class="back-home-btn" @click="goBack" title="返回首页">
          <span class="back-icon">←</span>
          <span class="back-text">返回首页</span>
        </button>
        <h1 class="logo">
          <span class="logo-icon">🎨</span>
          <span class="logo-text">创作者中心</span>
        </h1>
      </template>
      <template #center>
        <div class="nav-tabs">
          <button 
            v-for="tab in tabs" 
            :key="tab.id"
            :class="['nav-tab', { active: currentTab === tab.id }]"
            @click="currentTab = tab.id"
          >
            <span class="tab-icon">{{ tab.icon }}</span>
            <span class="tab-label">{{ tab.label }}</span>
          </button>
        </div>
      </template>
      <template #right>
        <div class="creator-stats">
          <div class="stat-item">
            <span class="stat-icon">💰</span>
            <span class="stat-value">{{ earnings.total }}</span>
            <span class="stat-label">总收益</span>
          </div>
          <div class="stat-item">
            <span class="stat-icon">📊</span>
            <span class="stat-value">{{ stats.themeCount }}</span>
            <span class="stat-label">主题数</span>
          </div>
          <div class="stat-item">
            <span class="stat-icon">👥</span>
            <span class="stat-value">{{ stats.followerCount }}</span>
            <span class="stat-label">粉丝</span>
          </div>
        </div>
      </template>
    </BaseHeader>

    <!-- 主内容区域 -->
    <main class="creator-main">
      <!-- 官方主题列表 -->
      <section v-if="currentTab === 'official'" class="section official-themes">
        <div class="section-header">
          <h2 class="section-title">
            <span class="title-icon">🏛️</span>
            <span class="title-text">官方主题</span>
          </h2>
          <div class="theme-filters">
            <button 
              :class="['filter-btn', { active: officialFilter === 'all' }]"
              @click="officialFilter = 'all'"
            >
              全部
            </button>
            <button 
              :class="['filter-btn', { active: officialFilter === 'game' }]"
              @click="officialFilter = 'game'"
            >
              游戏主题
            </button>
            <button 
              :class="['filter-btn', { active: officialFilter === 'app' }]"
              @click="officialFilter = 'app'"
            >
              应用主题
            </button>
          </div>
        </div>

        <div class="official-themes-grid">
          <div 
            v-for="theme in filteredOfficialThemes" 
            :key="theme.id"
            class="official-theme-card"
          >
            <div class="theme-header">
              <div class="theme-type-badge" :class="theme.type">
                {{ theme.type === 'game' ? '🎮 游戏' : '💼 应用' }}
              </div>
              <div class="theme-category">{{ theme.category }}</div>
            </div>
            
            <div class="theme-thumbnail">
              <div v-if="!theme.thumbnail" class="thumbnail-placeholder">
                <span class="placeholder-icon">{{ theme.type === 'game' ? '🎮' : '💼' }}</span>
              </div>
              <img 
                v-else 
                :src="theme.thumbnail" 
                :alt="theme.name"
                class="thumbnail-img"
              />
            </div>
            
            <div class="theme-info">
              <h3 class="theme-name">{{ theme.name }}</h3>
              <p class="theme-desc">{{ theme.description }}</p>
            </div>
            
            <div class="theme-actions">
              <button class="btn-action btn-view" @click="viewOfficialTheme(theme)">
                <span class="action-icon">👁️</span>
                <span>查看</span>
              </button>
              <button class="btn-action btn-diy" @click="diyFromOfficial(theme)">
                <span class="action-icon">✨</span>
                <span>DIY</span>
              </button>
            </div>
          </div>
        </div>
      </section>

      <!-- 我的主题管理 -->
      <section v-if="currentTab === 'my-themes'" class="section my-themes">
        <div class="section-header">
          <h2 class="section-title">我的主题</h2>
        </div>
        
        <div v-if="loading" class="loading-state">
          <div class="loading-spinner"></div>
          <p>加载中...</p>
        </div>

        <div v-else-if="myThemes.length === 0" class="empty-state">
          <div class="empty-illustration">🎨</div>
          <h3>还没有创建主题</h3>
          <p>前往 "官方主题" 选择喜欢的主题进行 DIY 创作吧！</p>
          <button class="btn-go-official" @click="currentTab = 'official'">
            浏览官方主题
          </button>
        </div>

        <div v-else class="themes-grid">
          <div 
            v-for="theme in myThemes" 
            :key="theme.id"
            class="theme-card"
            :class="{ 'on-sale': theme.status === 'on_sale' }"
          >
            <div class="theme-thumbnail" @click="editTheme(theme)">
              <img 
                v-if="theme.thumbnail" 
                :src="theme.thumbnail" 
                :alt="theme.name"
                class="thumbnail-img"
              />
              <div v-else class="thumbnail-placeholder">
                <span>{{ theme.name.charAt(0) }}</span>
              </div>
              <div v-if="theme.status === 'on_sale'" class="sale-badge">销售中</div>
              <div v-else class="offline-badge">已下架</div>
              <div class="theme-price">
                {{ theme.price > 0 ? `${theme.price} 趣乐币` : '免费' }}
              </div>
            </div>
            
            <div class="theme-info">
              <h3 class="theme-name">{{ theme.name }}</h3>
              <div class="theme-meta">
                <span class="theme-downloads">
                  <span class="meta-icon">⬇️</span>
                  {{ theme.downloadCount || 0 }}
                </span>
                <span v-if="theme.rating" class="theme-rating">
                  <span class="meta-icon">⭐</span>
                  {{ theme.rating.toFixed(1) }}
                </span>
                <span class="theme-earnings">
                  <span class="meta-icon">💰</span>
                  {{ theme.earnings || 0 }} 趣乐币
                </span>
              </div>
            </div>
            
            <div class="theme-actions">
              <button 
                class="btn-action"
                :class="theme.status === 'on_sale' ? 'btn-offline' : 'btn-online'"
                @click="toggleThemeSale(theme)"
                :disabled="isToggling"
              >
                {{ theme.status === 'on_sale' ? '下架' : '上架' }}
              </button>
              <button class="btn-action btn-edit" @click="editTheme(theme)">
                编辑
              </button>
              <button class="btn-action btn-stats" @click="viewThemeStats(theme)">
                数据
              </button>
            </div>
          </div>
        </div>
      </section>

      <!-- 主题商店 -->
      <section v-else-if="currentTab === 'store'" class="section theme-store">
        <div class="section-header">
          <h2 class="section-title">主题商店</h2>
          <div class="store-filters">
            <button 
              v-for="filter in storeFilters" 
              :key="filter.id"
              :class="['filter-btn', { active: storeFilter === filter.id }]"
              @click="storeFilter = filter.id"
            >
              {{ filter.label }}
            </button>
            <input 
              v-model="searchQuery" 
              type="text" 
              placeholder="搜索主题..." 
              class="search-input"
            />
          </div>
        </div>

        <div v-if="storeLoading" class="loading-state">
          <div class="loading-spinner"></div>
          <p>加载中...</p>
        </div>

        <div v-else-if="storeThemes.length === 0" class="empty-state">
          <div class="empty-illustration">🛍️</div>
          <h3>没有找到主题</h3>
          <p>尝试搜索其他关键词</p>
        </div>

        <div v-else class="store-grid">
          <div 
            v-for="theme in storeThemes" 
            :key="theme.id"
            class="store-theme-card"
            :class="{ owned: theme.owned }"
          >
            <div class="theme-thumbnail" @click="previewTheme(theme)">
              <img 
                v-if="theme.thumbnail" 
                :src="theme.thumbnail" 
                :alt="theme.name"
                class="thumbnail-img"
              />
              <div v-else class="thumbnail-placeholder">
                <span>{{ theme.name.charAt(0) }}</span>
              </div>
              <div v-if="theme.price === 0" class="free-badge">免费</div>
            </div>
            
            <div class="theme-info">
              <h3 class="theme-name">{{ theme.name }}</h3>
              <p class="theme-author">作者：{{ theme.author }}</p>
              <div class="theme-meta">
                <span class="theme-downloads">
                  <span class="meta-icon">⬇️</span>
                  {{ theme.downloadCount || 0 }}
                </span>
                <span v-if="theme.rating" class="theme-rating">
                  <span class="meta-icon">⭐</span>
                  {{ theme.rating.toFixed(1) }}
                </span>
              </div>
            </div>
            
            <div class="theme-footer">
              <div class="theme-price">
                {{ theme.price > 0 ? `${theme.price} 趣乐币` : '免费' }}
              </div>
              <button 
                class="btn-buy"
                :class="{ owned: theme.owned }"
                @click="handleBuyOrDownload(theme)"
                :disabled="isPurchasing"
              >
                {{ theme.owned ? '已拥有' : theme.price > 0 ? '购买' : '获取' }}
              </button>
            </div>
          </div>
        </div>
      </section>

      <!-- 主题创作（仅通过官方主题 DIY 进入） -->
      <section v-else-if="currentTab === 'create'" class="section theme-create">
        <div class="create-header-with-back">
          <button class="btn-cancel-create" @click="cancelCreate">
            <span class="cancel-icon">✕</span>
            <span>取消创作</span>
          </button>
          <div class="create-title-wrapper">
            <h2 class="create-title">主题创作</h2>
            <div v-if="diySourceTheme" class="diy-source-badge">
              <span class="source-icon">🎨</span>
              <span>基于：</span>
              <span class="source-theme-name">{{ diySourceTheme.name }}</span>
            </div>
          </div>
          <div class="create-placeholder"></div>
        </div>
        
        <div class="create-steps">
          <div 
            v-for="(step, index) in createSteps" 
            :key="step.id"
            :class="['create-step', { active: createStep === step.id }]"
          >
            <div class="step-number">{{ index + 1 }}</div>
            <div class="step-info">
              <h4 class="step-title">{{ step.title }}</h4>
              <p class="step-description">{{ step.description }}</p>
            </div>
          </div>
        </div>
        
        <!-- 基本信息步骤 -->
        <div v-if="createStep === 'info'" class="step-content info-step">
          <div class="diy-source-info" v-if="diySourceTheme">
            <div class="source-card">
              <div class="source-header">
                <span class="source-icon">📋</span>
                <h4 class="source-title">来源主题信息</h4>
              </div>
              <div class="source-details">
                <div class="detail-row">
                  <span class="detail-label">原主题名称：</span>
                  <span class="detail-value">{{ diySourceTheme.name }}</span>
                </div>
                <div class="detail-row">
                  <span class="detail-label">原主题描述：</span>
                  <span class="detail-value">{{ diySourceTheme.description || '暂无描述' }}</span>
                </div>
                <div class="detail-row">
                  <span class="detail-label">基础模板：</span>
                  <span class="detail-value">{{ newTheme.baseThemeKey }}</span>
                </div>
              </div>
            </div>
          </div>
          
          <div class="form-group">
            <label class="form-label">主题名称 <span class="required-mark">*</span></label>
            <input 
              v-model="newTheme.name" 
              type="text" 
              placeholder="请输入独特的主题名称" 
              class="form-input"
            />
          </div>
          <div class="form-group">
            <label class="form-label">作者名称 <span class="required-mark">*</span></label>
            <input 
              v-model="newTheme.author" 
              type="text" 
              placeholder="输入作者名称" 
              class="form-input"
            />
          </div>
          <div class="form-group">
            <label class="form-label">基于模板</label>
            <select v-model="newTheme.baseThemeKey" class="form-input">
              <option v-for="theme in baseThemes" :key="theme.key" :value="theme.key">
                {{ theme.name }}
              </option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">主题描述</label>
            <textarea 
              v-model="newTheme.description" 
              placeholder="描述你的主题特点..." 
              class="form-textarea"
              rows="3"
            ></textarea>
          </div>
          <div class="form-group">
            <label class="form-label">定价（趣乐币）</label>
            <input 
              v-model="newTheme.price" 
              type="number" 
              min="0" 
              class="form-input"
              placeholder="0 表示免费"
            />
            <div class="form-hint">设置 0 为免费主题，其他为付费主题</div>
          </div>
        </div>

        <!-- 样式配置步骤 -->
        <div v-else-if="createStep === 'styles'" class="step-content styles-step">
          <div class="style-editor">
            <div class="style-preview">
              <div class="preview-card" :style="previewStyles">
                <h3 class="preview-title" :style="{ color: newThemeStyles.color_text }">
                  {{ newTheme.name || '主题预览' }}
                </h3>
                <button 
                  class="preview-button"
                  :style="{
                    backgroundColor: newThemeStyles.color_primary,
                    borderRadius: newThemeStyles.border_radius_btn,
                  }"
                >
                  示例按钮
                </button>
              </div>
            </div>
            
            <div class="style-controls">
              <div class="style-group">
                <h4 class="style-group-title">颜色配置</h4>
                <div class="color-grid">
                  <div v-for="key in colorKeys" :key="key" class="color-field">
                    <label class="color-label">{{ formatStyleKey(key) }}</label>
                    <div class="color-input-wrapper">
                      <input 
                        v-model="newThemeStyles[key]"
                        type="color"
                        class="color-picker"
                      />
                      <input 
                        v-model="newThemeStyles[key]"
                        type="text"
                        class="color-text-input"
                        placeholder="#000000"
                      />
                    </div>
                  </div>
                </div>
              </div>
              
              <div class="style-group">
                <h4 class="style-group-title">尺寸配置</h4>
                <div class="size-grid">
                  <div v-for="key in sizeKeys" :key="key" class="size-field">
                    <label class="size-label">{{ formatStyleKey(key) }}</label>
                    <input 
                      v-model="newThemeStyles[key]"
                      type="text"
                      class="size-input"
                      placeholder="8px"
                    />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 资源上传步骤 -->
        <div v-else-if="createStep === 'assets'" class="step-content assets-step">
          <div class="asset-grid-container">
            <div class="grid-header">
              <h4 class="section-title-with-icon">
                <span class="title-icon">🎨</span>
                主题资源配置
              </h4>
              <div class="grid-stats">
                <span class="stats-badge">
                  ✅ 已上传：{{ Object.keys(newThemeAssets).length }} / {{ assetKeys.length }}
                </span>
              </div>
            </div>
            
            <!-- 调试信息 -->
            <div v-if="false" class="debug-info" style="background: #fff3cd; padding: 10px; margin-bottom: 10px; border-radius: 4px; font-size: 12px;">
              <div><strong>Debug:</strong></div>
              <div>assetKeys 数量：{{ assetKeys.length }}</div>
              <div>newThemeAssets 数量：{{ Object.keys(newThemeAssets).length }}</div>
              <div>assetKeys: {{ JSON.stringify(assetKeys) }}</div>
            </div>
            
            <!-- 空状态提示 -->
            <div v-if="assetKeys.length === 0" class="empty-assets-state">
              <div class="empty-illustration">⚠️</div>
              <h3>暂无可用资源键</h3>
              <p>基础主题配置尚未加载完成，请稍后...</p>
            </div>
            
            <div v-else class="asset-grid-wrapper">
              <!-- 所有资源卡片网格 -->
              <div class="asset-grid">
                <div 
                  v-for="key in assetKeys" 
                  :key="key"
                  class="asset-card"
                  :class="{ filled: newThemeAssets[key] }"
                >
                  <!-- 卡片内容 -->
                  <div class="card-content">
                    <!-- 资源类型标签 -->
                    <div class="card-type-badge" :class="getAssetTypeClass(key)">
                      {{ getAssetTypeLabel(key) }}
                    </div>
                    
                    <!-- 资源名称 -->
                    <div class="card-title">{{ formatAssetKey(key) }}</div>
                    
                    <!-- 预览区域 -->
                    <div class="card-preview-area">
                      <!-- 图片预览 -->
                      <div v-if="isImage(newThemeAssets[key])" class="preview-image-wrapper">
                        <img :src="newThemeAssets[key]" :alt="key" class="card-image" />
                        <div class="image-overlay">
                          <button class="overlay-action" @click="openImagePreview(key)">🔍</button>
                        </div>
                      </div>
                      
                      <!-- 音频播放 -->
                      <div v-else-if="isAudio(newThemeAssets[key])" class="preview-audio-wrapper">
                        <div class="audio-player-circle" :class="{ playing: currentPlayingKey === key }">
                          <span class="audio-icon">🎵</span>
                        </div>
                        <button 
                          class="play-button"
                          @click="playAudio(key)"
                          :class="{ playing: currentPlayingKey === key }"
                        >
                          {{ currentPlayingKey === key ? '⏹️' : '▶️' }}
                        </button>
                      </div>
                      
                      <!-- 空状态 -->
                      <div v-else class="preview-empty">
                        <span class="empty-icon">📭</span>
                      </div>
                    </div>
                    
                    <!-- 操作按钮 -->
                    <div class="card-actions">
                      <label class="btn-upload-card">
                        <input 
                          type="file"
                          :accept="getFileAccept(key)"
                          @change="(e) => handleAssetUpload(key, e)"
                          class="hidden-input"
                        />
                        <span class="upload-text">
                          {{ newThemeAssets[key] ? '🔄 替换' : '📤 上传' }}
                        </span>
                      </label>
                      
                      <button 
                        v-if="isImage(newThemeAssets[key])"
                        class="btn-card-action"
                        @click="openImagePreview(key)"
                      >
                        👁️
                      </button>
                      
                      <button 
                        v-if="isAudio(newThemeAssets[key])"
                        class="btn-card-action btn-audio-action"
                        @click="playAudio(key)"
                        :class="{ playing: currentPlayingKey === key }"
                      >
                        {{ currentPlayingKey === key ? '⏹️' : '▶️' }}
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 发布设置步骤 -->
        <div v-else-if="createStep === 'publish'" class="step-content publish-step">
          <div class="publish-summary">
            <div class="summary-card">
              <h4 class="summary-title">主题信息</h4>
              <div class="summary-item">
                <span class="item-label">主题名称：</span>
                <span class="item-value">{{ newTheme.name }}</span>
              </div>
              <div class="summary-item">
                <span class="item-label">作者名称：</span>
                <span class="item-value">{{ newTheme.author }}</span>
              </div>
              <div class="summary-item">
                <span class="item-label">定价：</span>
                <span class="item-value">
                  {{ newTheme.price > 0 ? `${newTheme.price} 趣乐币` : '免费' }}
                </span>
              </div>
              <div class="summary-item">
                <span class="item-label">资源数量：</span>
                <span class="item-value">
                  {{ Object.keys(newThemeAssets).length }} 个
                </span>
              </div>
            </div>
            
            <div class="publish-options">
              <div class="option-group">
                <label class="option-label">
                  <input 
                    v-model="publishOptions.saveLocally" 
                    type="checkbox" 
                    class="option-checkbox"
                  />
                  保存到本地
                </label>
                <p class="option-description">保存主题到本地库，方便后续编辑</p>
              </div>
              <div class="option-group">
                <label class="option-label">
                  <input 
                    v-model="publishOptions.uploadToStore" 
                    type="checkbox" 
                    class="option-checkbox"
                  />
                  发布到商店
                </label>
                <p class="option-description">将主题发布到主题商店，其他用户可以购买</p>
              </div>
              <div v-if="publishOptions.uploadToStore" class="option-group">
                <label class="option-label">发布状态</label>
                <select v-model="publishOptions.publishStatus" class="option-select">
                  <option value="draft">草稿</option>
                  <option value="on_sale">立即上架</option>
                </select>
              </div>
            </div>
          </div>
        </div>

        <!-- 导航按钮 -->
        <div class="create-navigation">
          <button 
            v-if="createStep !== 'info'" 
            class="btn-nav btn-prev"
            @click="prevStep"
          >
            上一步
          </button>
          <button 
            v-if="createStep !== 'publish'" 
            class="btn-nav btn-next"
            @click="nextStep"
            :disabled="!canProceed"
          >
            下一步
          </button>
          <button 
            v-if="createStep === 'publish'" 
            class="btn-nav btn-publish"
            @click="publishTheme"
            :disabled="!canPublish"
          >
            发布主题
          </button>
        </div>
      </section>

      <!-- 主题切换 -->
      <section v-else-if="currentTab === 'theme-switcher'" class="section theme-switcher">
        <div class="switcher-container">
          <div class="switcher-header">
            <h2 class="switcher-title">切换主题</h2>
            <p class="switcher-subtitle">选择您喜欢的主题应用到系统中</p>
          </div>
          
          <div v-if="loadingThemes" class="loading-state">
            <div class="loading-spinner"></div>
            <p>加载主题中...</p>
          </div>
          
          <div v-else class="themes-grid-switcher">
            <div 
              v-for="theme in availableThemes" 
              :key="theme.id"
              class="theme-option-switcher"
              :class="{ active: currentTheme?.id === theme.id }"
              @click="switchTheme(theme.id)"
            >
              <div class="theme-preview" :style="{ background: theme.previewColor }">
                <div class="color-palette">
                  <span 
                    v-for="(color, index) in theme.colorPalette" 
                    :key="index"
                    class="color-swatch"
                    :style="{ backgroundColor: color }"
                  ></span>
                </div>
              </div>
              
              <div class="theme-info-switcher">
