  loadMyThemes();
  loadCreatorData();
  loadBaseThemes();
  loadThemes();
  loadOfficialThemes(); // 从后台加载官方主题
});

// 加载所有可用主题
async function loadThemes(): Promise<void> {
  loadingThemes.value = true;
  try {
    // 这里应该从主题管理器获取所有可用主题
    // 暂时使用模拟数据
    availableThemes.value = [
      {
        id: 'default',
        name: '默认主题',
        description: '系统默认主题',
        type: 'system',
        price: 0,
        previewColor: '#4ECDC4',
        colorPalette: ['#4ECDC4', '#FF6B6B', '#45B7D1', '#96CEB4', '#FFEAA7'],
      },
      {
        id: 'kids',
        name: '儿童主题',
        description: '专为儿童设计的主题',
        type: 'system',
        price: 0,
        previewColor: '#FF6B6B',
        colorPalette: ['#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4', '#FFEAA7'],
      },
      {
        id: 'ocean',
        name: '海洋主题',
        description: '蓝色海洋风格主题',
        type: 'custom',
        price: 0,
        previewColor: '#45B7D1',
        colorPalette: ['#45B7D1', '#4ECDC4', '#96CEB4', '#FFEAA7', '#FF6B6B'],
      },
    ];
    
    // 获取当前主题
    const currentThemeId = themeManager.getCurrentThemeId?.();
    if (currentThemeId) {
      currentTheme.value = availableThemes.value.find(t => t.id === currentThemeId);
    }
  } catch (e) {
    console.error('[CreatorCenter] Load themes failed:', e);
  } finally {
    loadingThemes.value = false;
  }
}

// 切换主题
async function switchTheme(themeId: string): Promise<void> {
  try {
    const success = themeManager.switchTheme(themeId);
    if (success) {
      currentTheme.value = availableThemes.value.find(t => t.id === themeId);
      alert('主题切换成功！');
    } else {
      alert('主题切换失败');
    }
  } catch (e) {
    console.error('[CreatorCenter] Switch theme failed:', e);
    alert('主题切换失败');
  }
}

// 加载我的主题
async function loadMyThemes(): Promise<void> {
  loading.value = true;
  try {
    myThemes.value = await themeManager.getMyCloudThemes();
    stats.themeCount = myThemes.value.length;
  } catch (e) {
    console.error('[CreatorCenter] Failed to load themes:', e);
  } finally {
    loading.value = false;
  }
}

// 加载创作者数据
async function loadCreatorData(): Promise<void> {
  try {
    const earningsData = await themeManager.getCreatorEarnings();
    Object.assign(earnings, earningsData);
    
    // 模拟数据
    stats.followerCount = Math.floor(Math.random() * 1000);
    stats.downloads = Math.floor(Math.random() * 5000);
  } catch (e) {
    console.error('[CreatorCenter] Failed to load creator data:', e);
  }
}

// 加载基础主题
async function loadBaseThemes(): Promise<void> {
  try {
    await themeManager.loadBaseConfig();
    baseThemes.value = await themeManager.getAllThemes();
    colorKeys.value = themeManager.getBaseStyleKeys().filter(key => 
      key.toLowerCase().includes('color')
    );
    sizeKeys.value = themeManager.getBaseStyleKeys().filter(key => 
      key.toLowerCase().includes('size') || 
      key.toLowerCase().includes('radius')
    );
    assetKeys.value = themeManager.getBaseAssetKeys();
    console.log('[基础主题] 加载完成:', {
      baseThemesCount: baseThemes.value.length,
      colorKeysCount: colorKeys.value.length,
      sizeKeysCount: sizeKeys.value.length,
      assetKeysCount: assetKeys.value.length,
      assetKeys: assetKeys.value,
    });
  } catch (e) {
    console.error('[CreatorCenter] Failed to load base themes:', e);
  }
}

// 切换主题销售状态
async function toggleThemeSale(theme: CloudThemeInfo): Promise<void> {
  if (isToggling.value) return;
  
  isToggling.value = true;
  try {
    const newStatus = theme.status !== 'on_sale';
    const success = await themeManager.toggleThemeSale(theme.id, newStatus);
    if (success) {
      theme.status = newStatus ? 'on_sale' : 'offline';
      await loadMyThemes();
    } else {
      alert('操作失败，请重试');
    }
  } catch (e) {
    console.error('[CreatorCenter] Toggle sale failed:', e);
    alert('操作失败');
  } finally {
    isToggling.value = false;
  }
}

