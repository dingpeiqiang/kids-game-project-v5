{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kids-game.com/schemas/gtrs-v1.0.0.json",
  "title": "Game Theme Resource Specification v1.0.0",
  "description": "GTRS游戏主题资源规范Schema，用于全流程JSON校验",
  "type": "object",
  "required": ["specMeta", "themeInfo", "globalStyle", "resources"],
  "additionalProperties": false,
  "properties": {
    "specMeta": {
      "type": "object",
      "description": "规范元信息",
      "required": ["specName", "specVersion", "compatibleVersion"],
      "additionalProperties": false,
      "properties": {
        "specName": {
          "type": "string",
          "const": "GTRS",
          "description": "规范名称，固定为GTRS"
        },
        "specVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "当前规范版本号，格式：主版本.次版本.修订版"
        },
        "compatibleVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "向下兼容的最低版本"
        }
      }
    },
    "themeInfo": {
      "type": "object",
      "description": "主题基础信息",
      "required": ["themeId", "gameId", "themeName", "isDefault"],
      "additionalProperties": true,
      "properties": {
        "themeId": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "主题唯一标识，仅英文小写、数字、下划线"
        },
        "gameId": {
          "type": "string",
          "description": "归属游戏ID"
        },
        "themeName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "主题名称，支持中文"
        },
        "isDefault": {
          "type": "boolean",
          "description": "是否为默认兜底主题"
        },
        "author": {
          "type": "string",
          "description": "创作者名称"
        },
        "description": {
          "type": "string",
          "maxLength": 500,
          "description": "主题描述"
        }
      }
    },
    "globalStyle": {
      "type": "object",
      "description": "全局样式配置",
      "additionalProperties": true,
      "properties": {
        "primaryColor": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "主色调，十六进制颜色值"
        },
        "secondaryColor": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "辅助色"
        },
        "bgColor": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "背景色"
        },
        "textColor": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "文字颜色"
        },
        "fontFamily": {
          "type": "string",
          "description": "字体"
        },
        "borderRadius": {
          "type": "string",
          "description": "圆角大小"
        }
      }
    },
    "resources": {
      "type": "object",
      "description": "资源集合",
      "required": ["images", "audio", "video"],
      "additionalProperties": false,
      "properties": {
        "images": {
          "type": "object",
          "description": "图片资源",
          "required": ["login", "scene", "ui", "icon", "effect"],
          "additionalProperties": false,
          "properties": {
            "login": {
              "type": "object",
              "description": "登录相关图片",
              "additionalProperties": {
                "$ref": "#/definitions/imageResource"
              }
            },
            "scene": {
              "type": "object",
              "description": "游戏场景图片",
              "additionalProperties": {
                "$ref": "#/definitions/imageResource"
              }
            },
            "ui": {
              "type": "object",
              "description": "UI界面图片",
              "additionalProperties": {
                "$ref": "#/definitions/imageResource"
              }
            },
            "icon": {
              "type": "object",
              "description": "图标图片",
              "additionalProperties": {
                "$ref": "#/definitions/imageResource"
              }
            },
            "effect": {
              "type": "object",
              "description": "特效图片",
              "additionalProperties": {
                "$ref": "#/definitions/imageResource"
              }
            }
          }
        },
        "audio": {
          "type": "object",
          "description": "音频资源",
          "required": ["bgm", "effect", "voice"],
          "additionalProperties": false,
          "properties": {
            "bgm": {
              "type": "object",
              "description": "背景音乐",
              "additionalProperties": {
                "$ref": "#/definitions/audioResource"
              }
            },
            "effect": {
              "type": "object",
              "description": "音效",
              "additionalProperties": {
                "$ref": "#/definitions/audioResource"
              }
            },
            "voice": {
              "type": "object",
              "description": "语音",
              "additionalProperties": {
                "$ref": "#/definitions/audioResource"
              }
            }
          }
        },
        "video": {
          "type": "object",
          "description": "视频资源（预留扩展）",
          "additionalProperties": true
        }
      }
    }
  },
  "definitions": {
    "imageResource": {
      "type": "object",
      "required": ["src", "type", "alias"],
      "additionalProperties": false,
      "properties": {
        "src": {
          "type": "string",
          "minLength": 1,
          "description": "资源路径（URL或相对路径）"
        },
        "type": {
          "type": "string",
          "enum": ["png", "jpg", "jpeg", "webp", "gif"],
          "description": "图片格式"
        },
        "alias": {
          "type": "string",
          "minLength": 1,
          "description": "中文别名（可视化界面使用）"
        }
      }
    },
    "audioResource": {
      "type": "object",
      "required": ["src", "type", "alias", "volume"],
      "additionalProperties": false,
      "properties": {
        "src": {
          "type": "string",
          "minLength": 1,
          "description": "资源路径"
        },
        "type": {
          "type": "string",
          "enum": ["mp3", "wav", "ogg"],
          "description": "音频格式"
        },
        "alias": {
          "type": "string",
          "minLength": 1,
          "description": "中文别名"
        },
        "volume": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "音量（0~1）"
        }
      }
    }
  }
}
