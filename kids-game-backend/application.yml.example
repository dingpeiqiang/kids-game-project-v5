# ========================================
# 腾讯 COS 配置示例文件
# 
# 使用说明：
# 1. 复制此文件为 application.yml
# 2. 修改下面的配置值
# 3. 重启后端服务
# ========================================

server:
  port: 8080
  servlet:
    context-path: /

spring:
  application:
    name: kids-game-backend
  
  # 数据库配置（请根据实际情况修改）
  datasource:
    url: jdbc:mysql://localhost:3306/kids_game?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false
    username: root
    password: your-password
    driver-class-name: com.mysql.cj.jdbc.Driver
  
  # 文件上传配置
  servlet:
    multipart:
      max-file-size: 50MB
      max-request-size: 50MB

# ========================================
# 腾讯 COS 配置（重要！请修改以下配置）
# ========================================
tencent:
  cos:
    # 从环境变量读取，如果没有则使用默认值
    secret-id: ${COS_SECRET_ID:your-secret-id-here}
    secret-key: ${COS_SECRET_KEY:your-secret-key-here}
    bucket: kids-game-resources-${COS_APP_ID:your-app-id-here}
    region: ${COS_REGION:ap-guangzhou}

# ========================================
# 资源上传配置
# ========================================
resource:
  upload:
    # 本地上传路径（当 VITE_UPLOAD_METHOD=local 时使用）
    path: ./uploads
  
  cdn:
    # CDN 域名（可选，如果使用了 CDN 加速请配置）
    # 例如：https://cdn.example.com
    domain: ""

# ========================================
# JWT 配置
# ========================================
jwt:
  secret: your-jwt-secret-key-here-please-change-in-production
  expiration: 86400000  # 24 小时

# ========================================
# MyBatis-Plus 配置
# ========================================
mybatis-plus:
  mapper-locations: classpath*:/mapper/**/*.xml
  type-aliases-package: com.kidgame.**.model
  configuration:
    map-underscore-to-camel-case: true
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl

# ========================================
# 日志配置
# ========================================
logging:
  level:
    root: INFO
    com.kidgame: DEBUG
  pattern:
    console: '%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n'
    file: '%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n'
  file:
    name: ./logs/kids-game.log
    max-size: 10MB
    max-history: 30

# ========================================
# CORS 配置（开发环境可以宽松一些）
# ========================================
cors:
  allowed-origins: "*"
  allowed-methods:GET,POST,PUT,DELETE,OPTIONS
  allowed-headers: "*"
  allow-credentials: true
  max-age: 3600

# ========================================
# SFTP 配置（可选）
# ========================================
# sftp:
#   # 是否启用 SFTP（启用后将优先使用 SFTP 上传）
#   enabled: false
#   # SFTP 服务器地址
#   host: sftp.example.com
#   # SFTP 服务器端口（默认22）
#   port: 22
#   # 用户名
#   username: your-username
#   # 密码（密码认证方式）
#   password: your-password
#   # 私钥文件路径（密钥认证方式，与密码二选一）
#   # private-key-path: /path/to/private_key
#   # 私钥 passphrase（如有）
#   # passphrase: your-passphrase
#   # 基础目录 - SFTP服务器上的根目录
#   base-directory: /upload
#   # 访问基础URL - 用于构建返回的文件访问URL
#   # 可以是完整URL（如 https://cdn.example.com）或相对路径（如 /resources）
#   base-url: /resources
#   # 连接超时（毫秒）
#   connection-timeout: 10000
#   # 读取超时（毫秒）
#   read-timeout: 30000
