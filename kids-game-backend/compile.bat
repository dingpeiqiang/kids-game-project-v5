@echo off
REM =====================================================
REM Maven 编译脚本
REM =====================================================

echo ======================================
echo 正在编译项目...
echo ======================================
echo.

cd /d %~dp0

call mvn clean compile -DskipTests

if %ERRORLEVEL% EQU 0 (
    echo.
    echo ======================================
    echo 编译成功完成！
    echo ======================================
) else (
    echo.
    echo ======================================
    echo 编译失败，错误代码：%ERRORLEVEL%
    echo ======================================
)

echo.
pause
