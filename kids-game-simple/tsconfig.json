{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../kids-game-frontend/src/*"],
      "@simple/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "../kids-game-frontend/src/**/*.ts",
    "../kids-game-frontend/src/**/*.vue"
  ],
  "exclude": ["node_modules", "dist"]
}